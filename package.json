{
  "name": "aestora-desktop",
  "version": "1.0.0",
  "description": "Aestora Desktop Application - Download premium After Effects leaks",
  "author": "Aestora",
  "main": "main.js",
  "scripts": {
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "27.0.0",
    "electron-builder": "24.6.4"
  },
  "build": {
    "appId": "com.aestora.app",
    "productName": "Aestora",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
